{
  "name": "kafka-activity-microservice",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "kafka:list": "docker exec -it kafka kafka-topics --bootstrap-server kafka:9093 --list",
    "kafka:describe": "docker exec -it kafka kafka-topics --bootstrap-server kafka:9093 --describe --topic",
    "kafka:create": "docker exec -it kafka kafka-topics --bootstrap-server kafka:9093 --create --topic",
    "kafka:alter-partitions": "docker exec -it kafka kafka-topics --bootstrap-server kafka:9093 --alter --topic",
    "kafka:produce": "docker exec -i kafka kafka-console-producer --bootstrap-server kafka:9093 --topic",
    "kafka:consume": "docker exec -it kafka kafka-console-consumer --bootstrap-server kafka:9093 --topic activity-logs --from-beginning --max-messages 5"
  },
